class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        if not s:
            return 0
        l = 0
        r = 0
        last_seen = {}
        max_len = 0
        for r in range(len(s)):
            if s[r] in last_seen:
                max_len = max(max_len, r - l)
                l = max(l, last_seen[s[r]] + 1)  
            last_seen[s[r] = r
        max_len = max(max_len, r - l + 1)
        return max_len
